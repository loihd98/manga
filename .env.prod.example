# ============================================
# Production Environment Configuration
# Copy this file to .env.prod and fill in values
# ============================================

# Database
POSTGRES_DB=web_truyen
POSTGRES_USER=webtruyen_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# JWT Secrets (generate with: openssl rand -base64 48)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48

# OAuth (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Base URLs
BASE_URL=https://vivutruyenhay.com
CORS_ORIGIN=https://vivutruyenhay.com
FRONTEND_URL=https://vivutruyenhay.com
BACKEND_URL=https://vivutruyenhay.com
DOMAIN=vivutruyenhay.com

# Frontend (Next.js public env vars — baked into build)
NEXT_PUBLIC_API_URL=https://vivutruyenhay.com/api
NEXT_PUBLIC_BASE_URL=https://vivutruyenhay.com
NEXT_PUBLIC_MEDIA_URL=https://vivutruyenhay.com
NEXT_PUBLIC_SITE_URL=https://vivutruyenhay.com

# Server-side API URL (internal Docker network — used for SSR)
API_URL=http://backend:5000/api

# File upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=/uploads

# Environment
NODE_ENV=production
PORT=5000
FRONTEND_PORT=3000

# Email (optional — for contact form)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
